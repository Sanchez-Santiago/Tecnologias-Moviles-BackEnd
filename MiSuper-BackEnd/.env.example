# ────────────────────────────────────────────
# SUPABASE / PostgreSQL
# ────────────────────────────────────────────
DATABASE_URL=jdbc:postgresql://aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_USER=postgres.xxxxxxxxxxxxxxxxxxxx
DATABASE_PASSWORD=your-supabase-password

# ────────────────────────────────────────────
# JWT
# ────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-256-bit-secret
JWT_ISSUER=misuper-backend
JWT_AUDIENCE=misuper-app
ACCESS_TOKEN_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_DAYS=7

# ────────────────────────────────────────────
# PASSWORD
# ────────────────────────────────────────────
PASSWORD_PEPPER=change-me-to-a-random-pepper
